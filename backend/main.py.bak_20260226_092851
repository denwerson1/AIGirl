@app.post("/events")
def create_event(payload: EventIn) -> Dict[str, Any]:
    if not payload.character_key:
        raise HTTPException(status_code=400, detail="character_key required")
    # pack payload json
    packed = payload.payload or {}
    if payload.text is not None:
        packed["text"] = payload.text
    packed["platform"] = payload.platform
    packed["channel"] = payload.channel
    packed["event_type"] = payload.event_type
    packed["conversation_key"] = payload.conversation_key
    packed["lang"] = payload.lang
    with get_cnx(autocommit=False) as cn:
        cur = cn.cursor()
        # validate character exists
        _ = _get_character_id(cur, payload.character_key)
        cur.execute(
            "INSERT INTO dbo.InteractionEvents(Platform, Channel, ConversationKey, CharacterKey, EventType, PayloadJson, Lang, Sentiment, EngagementScore, AdminScore) "
            "VALUES(?,?,?,?,?,?,?,?,?,?)",
            payload.platform, payload.channel, payload.conversation_key, payload.character_key,
            payload.event_type, json.dumps(packed, ensure_ascii=False), payload.lang,
            payload.sentiment, payload.engagement, payload.admin_score
        )
        cur.execute("SELECT SCOPE_IDENTITY()")
        eid = int(cur.fetchone()[0])
        cn.commit()
    return {"ok": True, "event_id": eid}
