def get_cnx(autocommit: bool = False) -> pyodbc.Connection:
    """
    Create a DB connection.
    Behavior:
      1) If DB_USER/DB_PASSWORD are provided → try SQL Authentication.
      2) If SQL Authentication fails → fall back to Integrated Security.
      3) If DB_USER/DB_PASSWORD are not provided → Integrated Security.
    """
    driver = _env("DB_DRIVER", "ODBC Driver 17 for SQL Server")
    server = _env("DB_SERVER")
    database = _env("DB_NAME", "AIGirl")
    user = _env("DB_USER")
    pwd = _env("DB_PASSWORD")
    if not server:
        raise RuntimeError("DB_SERVER is not set in backend/.env")
    cs_integrated = (
        f"Driver={{{driver}}};"
        f"Server={server};"
        f"Database={database};"
        "Trusted_Connection=yes;"
        "TrustServerCertificate=yes;"
    )
    if user and pwd:
        cs_sql = (
            f"Driver={{{driver}}};"
            f"Server={server};"
            f"Database={database};"
            f"UID={user};"
            f"PWD={pwd};"
            "TrustServerCertificate=yes;"
        )
        try:
            return pyodbc.connect(cs_sql, autocommit=autocommit)
        except pyodbc.Error as e:
            logger.warning("SQL auth failed, falling back to Integrated Security: %s", str(e))
            return pyodbc.connect(cs_integrated, autocommit=autocommit)
    return pyodbc.connect(cs_integrated, autocommit=autocommit)
